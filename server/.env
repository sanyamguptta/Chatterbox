# Database — update with your actual PostgreSQL credentials
DATABASE_URL=postgresql://sanyam@localhost:5432/chatterbox

# JWT — change these to random strings before deploying
JWT_SECRET=chatterbox_jwt_secret_change_me_in_prod_32chars
REFRESH_SECRET=chatterbox_refresh_secret_change_me_in_prod

# Resend (OTP emails) — get your key at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# College config
COLLEGE_EMAIL_DOMAIN=cgc.edu.in
COLLEGE_NAME=Chandigarh Group of Colleges

# App — port 5001 to avoid conflict with macOS AirPlay on 5000
PORT=5001
CLIENT_URL=http://localhost:5173
NODE_ENV=development
